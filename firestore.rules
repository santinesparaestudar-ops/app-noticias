rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Qualquer pessoa pode ler as notícias (é um app público).
    // Só o robô (Admin SDK, via GitHub Actions) pode escrever — o Admin SDK ignora estas regras.
    match /noticias/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Qualquer visitante pode se cadastrar para notificações (criar/reativar seu próprio token,
    // já que o mesmo dispositivo pode reenviar o mesmo token em visitas futuras),
    // mas ninguém pode ler ou apagar tokens de outras pessoas pelo app.
    match /push_tokens/{tokenId} {
      allow create, update: if true;
      allow read, delete: if false;
    }
  }
}
